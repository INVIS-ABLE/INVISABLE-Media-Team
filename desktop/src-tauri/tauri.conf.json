{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "INVISABLE Media Team",
  "version": "0.1.0",
  "identifier": "uk.co.invisable.media.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "INVISABLE® Media Team",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost http: https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "deb", "appimage", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "category": "Productivity",
    "shortDescription": "INVISABLE® Media Command Centre & Studio Worker",
    "longDescription": "The desktop control surface for the INVISABLE® Media Team OS. Runs as the server-side Command Centre or the 5090 Studio Worker, connecting to the protected media PWA/API."
  },
  "plugins": {}
}
