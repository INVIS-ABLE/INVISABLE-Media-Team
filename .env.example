# ============================================================================
# INVISABLE® AI Media Agency OS — environment configuration
# Copy to .env and fill in. Every value has a safe default; the platform runs
# in a degraded-but-functional mode when credentials are absent.
# ============================================================================

# --- Core API ---------------------------------------------------------------
INVISABLE_ENV=development
INVISABLE_API_HOST=0.0.0.0
INVISABLE_API_PORT=8080
INVISABLE_LOG_LEVEL=INFO
# Optional API key gating the /v1 surface. Leave empty to keep the API open
# (offline/dev default). When set, every /v1 request must send it via the
# X-API-Key header (or Authorization: Bearer). For human access, put Cloudflare
# Access in front of the tunnel; this key is the programmatic gate (n8n, the PWA).
INVISABLE_API_KEY=

# --- Brand / Founder --------------------------------------------------------
INVISABLE_BRAND_NAME=INVISABLE
INVISABLE_FOUNDER_NAME=Stephen Garnham
# Target share of published content that centres the founder (0.0 - 1.0)
INVISABLE_FOUNDER_PRESENCE_TARGET=0.80

# --- Reasoning / LLMs -------------------------------------------------------
# Claude (preferred for the highest-stakes reasoning & final selection).
ANTHROPIC_API_KEY=
INVISABLE_CLAUDE_MODEL=claude-opus-4-8
INVISABLE_CLAUDE_FAST_MODEL=claude-sonnet-4-6
# Ollama (local generation at volume — Qwen / DeepSeek).
OLLAMA_BASE_URL=http://ollama:11434
INVISABLE_OLLAMA_MODEL=qwen2.5:14b
# LLM-judge re-ranks the top contenders on top of the deterministic floor. It is on
# automatically when a Claude key is set. To force it on with Ollama only (accepting
# the per-call latency), set this to 1.
INVISABLE_USE_JUDGE=

# --- Memory -----------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://invisable:invisable@postgres:5432/invisable
CHROMA_HOST=chroma
CHROMA_PORT=8000

# --- Harvesting (public sources only) --------------------------------------
FIRECRAWL_API_KEY=
FEEDLY_ACCESS_TOKEN=
GOOGLE_TRENDS_GEO=GB

# --- Publishing -------------------------------------------------------------
POSTIZ_API_URL=
POSTIZ_API_KEY=
# Map our platforms → Postiz integration ids (JSON), e.g.
# {"instagram":"intg_1","tiktok":"intg_2"}. Posts are sent to integration ids.
POSTIZ_INTEGRATIONS=
# Override the Postiz posts endpoint if your instance differs.
POSTIZ_POSTS_PATH=/public/v1/posts

# --- Asset library (ResourceSpace DAM) --------------------------------------
RESOURCESPACE_URL=
RESOURCESPACE_USER=
RESOURCESPACE_PRIVATE_KEY=

# --- Metrics (Metricool → Watchtower) ---------------------------------------
METRICOOL_API_TOKEN=
METRICOOL_BLOG_ID=

# --- Tooling bridge ---------------------------------------------------------
COMPOSIO_API_KEY=

# --- Media generation -------------------------------------------------------
# ComfyUI (images via Flux, video via Wan/Hunyuan/LTX) on the GPU machine.
COMFYUI_BASE_URL=http://comfyui:8188
COMFYUI_CHECKPOINT=v1-5-pruned-emaonly.safetensors
COMFYUI_IMAGE_SIZE=1024
# Optional: a custom workflow JSON with %PROMPT%/%SEED%/%WIDTH%/%HEIGHT% placeholders.
COMFYUI_WORKFLOW=
# ElevenLabs voiceover.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2
# Force the media pipeline to write real files (captions/text) even with no GPU/keys.
INVISABLE_MEDIA_OUT=

# --- n8n --------------------------------------------------------------------
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_ENCRYPTION_KEY=change-me-32-characters-minimum-xx

# --- Desktop apps (Command Centre / Studio Worker) --------------------------
# Server-issued bearer token the desktop apps present to the /api/* surface.
# Leave blank for an open LAN/localhost dev posture; set it in production so the
# desktop API requires Authorization: Bearer <token>. The same value is pasted into
# the desktop app (Settings → Authentication) and stored in the OS keychain.
INVISABLE_DESKTOP_TOKEN=
# Back-compat alias also accepted by the API token gate.
INVISABLE_API_TOKEN=
# Where the server stores assets uploaded by the 5090 Studio worker.
INVISABLE_UPLOAD_DIR=./data/uploads
